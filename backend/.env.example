# ── Required ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leetcode-tracker?retryWrites=true&w=majority

# ── Optional ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Render — do not set manually in production
PORT=5001

# ── LeetCode API ──────────────────────────────────────────────────────────────
# No token or API key needed — uses public GraphQL endpoint
# https://leetcode.com/graphql
