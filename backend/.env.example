PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leetcode-tracker?retryWrites=true&w=majority
NODE_ENV=production
FRONTEND_URL=https://your-app.netlify.app

# ── GitHub Sync ──────────────────────────────────────────────────────────────
# Personal Access Token — needs "repo" (read) scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Webhook secret — set the same value in your GitHub repo webhook settings
# GitHub repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
