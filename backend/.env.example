# ── Required ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leetcode-tracker?retryWrites=true&w=majority

# ── Optional ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Render — do not set manually in production
PORT=5001

# ── LeetCode Auto-Sync (required for POST /api/problem/sync) ──────────────────
# Your LeetCode username (shown in your profile URL: leetcode.com/u/<username>)
LEETCODE_USERNAME=invisiblemanfromheart

# Session cookie — get from browser:
#   1. Log in to leetcode.com
#   2. Open DevTools → Application → Cookies → leetcode.com
#   3. Copy value of "LEETCODE_SESSION"
LEETCODE_SESSION=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..AwUlvLy03_LEQgrMjsyyXthgFuWFpjKdTEgPLy92h5k

# CSRF token — same place as above, copy value of "csrftoken"
LEETCODE_CSRF=HE8Yj9Kil3rmJm6Lq0Gb28ywiFUZu7RO

# ── Codeforces Auto-Sync (required for POST /api/codeforces/sync) ─────────────
# Your Codeforces handle (shown in your profile URL: codeforces.com/profile/<handle>)
CF_HANDLE=priyanshuguptacoder
